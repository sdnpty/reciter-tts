<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ReciterTTS" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/accent_surface</item>
        <item name="colorOnPrimaryContainer">@color/primary_light</item>
        <item name="colorSecondary">@color/primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/primary</item>
        <item name="colorOnSecondaryContainer">@color/white</item>
        <item name="colorSurface">@color/bg_elevated</item>
        <item name="colorSurfaceVariant">@color/bg_surface</item>
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOutline">@color/glass_border</item>
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorControlActivated">@color/primary</item>
        <item name="colorControlHighlight">@color/selection_highlight</item>
        <item name="android:textColorHighlight">@color/selection_highlight</item>
        <item name="android:textSelectHandle">@color/primary</item>
        <item name="bottomNavigationStyle">@style/BottomNavStyle</item>
    </style>

    <style name="BottomNavStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@drawable/bg_bottom_nav</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/BottomNavIndicatorStyle</item>
        <item name="itemPaddingTop">10dp</item>
        <item name="itemPaddingBottom">10dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="BottomNavIndicatorStyle" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/accent_surface</item>
        <item name="android:width">64dp</item>
        <item name="android:height">34dp</item>
        <item name="marginHorizontal">10dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Full</item>
    </style>
</resources>
