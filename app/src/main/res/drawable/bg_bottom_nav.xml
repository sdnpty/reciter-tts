<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom navigation surface: a hairline top divider over the elevated fill,
     so the bar reads as a distinct layer matching the dark-glass cards. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_border" />
        </shape>
    </item>
    <item android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_elevated" />
        </shape>
    </item>
</layer-list>
